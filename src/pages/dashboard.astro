---
import AppLayout from "../layouts/AppLayout.astro";
import SmartAdd from "../components/SmartAdd.astro";
import IncomeAdd from "../components/IncomeAdd.astro";
import ExpenseList from "../components/ExpenseList.astro";
---

<AppLayout title="Dashboard — Zeken" pageTitle="Dashboard" pageSubtitle="Track your spending and income for the current month.">
    <div class="dashboard-layout dashboard-layout--fullscreen" id="dashboard-layout">
        <div class="dashboard-left" id="dashboard-left">
            <div id="add-section-wrap">
                <SmartAdd />
            </div>
            <div id="income-add-section" style="display: none;">
                <IncomeAdd />
            </div>
        </div>

        <div class="dashboard-right" id="dashboard-right">
            <ExpenseList categoriesTabFirst={true} />
        </div>
    </div>
</AppLayout>

<script>
    import { API } from '../lib/api';
    import { Store } from '../lib/store';
    import { UI } from '../lib/ui-utils';
    import { Renderers } from '../lib/renderers';
    import type { CategoryMap, Record } from '../lib/types';

    let CATS: CategoryMap = {};
    let INCOME_CATS: CategoryMap = {};
    let activeFilter = 'all';

    async function renderAll() {
        const month = Store.getCurrentMonth();
        const year = Store.getCurrentYear();
        const all = await API.loadRecords();

        const filteredByMonth = all.filter(r => {
            const [y, m] = r.date.split('-');
            return parseInt(m) - 1 === month && parseInt(y) === year;
        });

        Renderers.renderStats(filteredByMonth, 'dashboard', month, year);
        Renderers.renderSidebarTotal(filteredByMonth);
        Renderers.renderCategoryBars(filteredByMonth, CATS);
        
        Renderers.renderFilters(filteredByMonth, CATS, INCOME_CATS, (catId) => {
            activeFilter = catId || 'all';
            const displayList = activeFilter === 'all' 
                ? filteredByMonth 
                : filteredByMonth.filter(r => r.categoryId === activeFilter);
            displayList.sort((a,b) => new Date(b.date).getTime() - new Date(a.date).getTime());
            Renderers.renderList(filteredByMonth, CATS, INCOME_CATS, renderAll, activeFilter);
        });

        Renderers.renderList(filteredByMonth, CATS, INCOME_CATS, renderAll, activeFilter);
    }

    async function handleConfirm() {
        const nameEl = document.getElementById('p-name') as HTMLInputElement;
        const amtEl = document.getElementById('p-amount') as HTMLInputElement;
        const catEl = document.getElementById('p-category') as HTMLSelectElement;
        const locEl = document.getElementById('p-location') as HTMLInputElement;
        const dateEl = document.getElementById('p-date') as HTMLInputElement;

        if (!nameEl?.value || !amtEl?.value) return;
        const amount = parseFloat(amtEl.value);
        if (!Number.isFinite(amount) || amount < 0) {
            UI.showToast('Amount must be zero or more');
            return;
        }

        const record = {
            type: 'expense' as const,
            name: nameEl.value,
            amount,
            categoryId: catEl.value,
            location: locEl?.value || '',
            date: dateEl.value,
            created: new Date().toISOString()
        };

        await API.addRecord(record);
        nameEl.value = '';
        amtEl.value = '';
        UI.showToast(`✓ Added ${record.name}`);
        renderAll();
    }

    // Initialization
    document.addEventListener('astro:page-load', async () => {
        UI.initSidebar();
        
        const hasUser = await API.requireUser();
        if (!hasUser) return;

        const { CATS: c, INCOME_CATS: ic } = await API.loadCategories();
        CATS = c;
        INCOME_CATS = ic;

        const pCat = document.getElementById('p-category');
        if (pCat) {
            pCat.innerHTML = Object.entries(CATS).map(([id, cat]) => 
                `<option value="${id}">${cat.emoji} ${cat.label}</option>`
            ).join('');
        }

        const btnConfirm = document.getElementById('btn-confirm');
        if (btnConfirm) btnConfirm.onclick = handleConfirm;

        UI.initDateInputBounds('p-date');
        UI.initMonthNavigation(renderAll);
        UI.bindDataRefresh(renderAll);
        renderAll();
    });
</script>

<style>
    :global(.main-shell:has(#dashboard-layout)) {
        --dashboard-gap: 18px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        grid-template-rows: auto auto minmax(0, 1fr);
        gap: var(--dashboard-gap);
        min-height: 100%;
        align-content: start;
        overflow: auto;
        padding-right: 4px;
    }

    :global(.main-shell:has(#dashboard-layout) > .topbar),
    :global(.main-shell:has(#dashboard-layout) > .stats-row),
    :global(.main-shell:has(#dashboard-layout) > .page-body) {
        grid-column: 1 / -1;
        margin: 0;
    }

    :global(.main-shell:has(#dashboard-layout) > .page-body) {
        display: contents;
        overflow: visible;
        padding-right: 0;
    }

    :global(.main-shell:has(#dashboard-layout) > .stats-row) {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: var(--dashboard-gap);
    }

    :global(.main-shell:has(#dashboard-layout) > .stats-row .stat-card) {
        min-width: 0;
        padding-block: 22px;
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }

    :global(.main-shell:has(#dashboard-layout) > .stats-row .stat-card:hover) {
        box-shadow: 0 18px 36px rgba(15, 23, 42, 0.12);
    }

    :global(#dashboard-layout.dashboard-layout--fullscreen) {
        display: contents;
    }

    :global(#dashboard-left),
    :global(#dashboard-right) {
        grid-column: span 2;
        min-width: 0;
        min-height: 34rem;
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    :global(#dashboard-left > #add-section-wrap) {
        min-height: auto;
    }

    :global(#dashboard-right > #records-panel) {
        flex: 1;
        min-height: auto;
    }

    :global(#dashboard-right #records-panel),
    :global(#dashboard-right #view-categories.active),
    :global(#dashboard-right .categories-panel) {
        min-height: auto;
    }

    :global(#dashboard-left .add-section) {
        padding-block: 26px;
    }

    :global(#dashboard-right #records-panel) {
        gap: 16px;
    }

    :global(#dashboard-right .categories-panel) {
        padding: 22px;
    }

    :global(#dashboard-right .cat-row) {
        gap: 16px;
    }

    :global(#dashboard-right .cat-bar-item) {
        gap: 12px;
    }

    @media (max-width: 1100px) {
        :global(.main-shell:has(#dashboard-layout)) {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        :global(.main-shell:has(#dashboard-layout) > .stats-row) {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        :global(#dashboard-left),
        :global(#dashboard-right) {
            grid-column: 1 / -1;
            min-height: 0;
        }
    }

    @media (max-width: 720px) {
        :global(.main-shell:has(#dashboard-layout)) {
            grid-template-columns: 1fr;
        }

        :global(.main-shell:has(#dashboard-layout) > .stats-row) {
            grid-template-columns: 1fr;
        }
    }
</style>
