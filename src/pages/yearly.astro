---
import AppLayout from "../layouts/AppLayout.astro";
import YearlyTracking from "../components/YearlyTracking.astro";
---

<AppLayout title="Yearly Overview — Zeken" suppressStats={true} pageTitle="Yearly" pageSubtitle="Track how each month rolled up across the full year.">
    <div id="view-yearly" class="panel-view">
        <YearlyTracking />
    </div>
</AppLayout>

<script>
    import { API } from '../lib/api';
    import { Store } from '../lib/store';
    import { UI } from '../lib/ui-utils';
    import { Renderers } from '../lib/renderers';
    import { DataSpecs, useData } from '../lib/app.data';
    import type { Category, Pool } from '../lib/types';

    let expenseCategories: Category[] = [];
    let currentPools: Pool[] = [];

    function formatMoney(value: number) {
        return `€${value.toFixed(2)}`;
    }

    function escapeHtml(value: string) {
        return UI.esc(value);
    }

    function renderPoolCard(pool: Pool) {
        const isRollover = pool.type === 'rollover';
        const targetMarkup = typeof pool.target === 'number' && pool.target > 0
            ? `
                <div class="pool-progress">
                    <div class="pool-progress-row">
                        <span>Target</span>
                        <span>${formatMoney(pool.target)}</span>
                    </div>
                    <div class="pool-progress-bar">
                        <div class="pool-progress-fill" style="width: ${Math.min((pool.availableBalance / pool.target) * 100, 100)}%"></div>
                    </div>
                </div>
            `
            : '';

        const categoriesMarkup = pool.linkedCategories.length > 0
            ? `
                <div class="pool-categories">
                    ${pool.linkedCategories.map((category) => `
                        <span class="pool-category-tag">
                            <span>${escapeHtml(category.emoji)}</span>
                            <span>${escapeHtml(category.name)}</span>
                        </span>
                    `).join('')}
                </div>
            `
            : !isRollover ? '<p class="pool-meta">No categories linked yet.</p>' : '';
        
        const historyMarkup = pool.withdrawals && pool.withdrawals.length > 0
            ? `
                <div class="pool-history" id="history-${pool.id}" style="display: none;">
                    <h6>Recent Withdrawals</h6>
                    ${pool.withdrawals.slice(0, 5).map(w => `
                        <div class="pool-history-item">
                            <span>${w.description || 'Withdrawal'}</span>
                            <span class="neg">-${formatMoney(w.amount)}</span>
                        </div>
                    `).join('')}
                </div>
            ` : '';

        return `
            <article class="pool-item ${isRollover ? 'rollover-pool' : 'savings-pool'} ${pool.isClosed ? 'closed-pool' : ''}">
                <div class="pool-status-header">
                    <span class="pool-type-chip">${isRollover ? 'Rollover' : (pool.isClosed ? 'Completed' : 'Savings pool')}</span>
                    <div class="pool-controls">
                        ${!isRollover ? `
                        <button class="btn-pool-edit" data-id="${pool.id}" title="Edit pool">✎</button>
                        <button class="btn-pool-status" data-id="${pool.id}" data-closed="${pool.isClosed}" title="${pool.isClosed ? 'Reopen pool' : 'Mark as done'}">
                            ${pool.isClosed ? '↺' : '✓'}
                        </button>
                        ` : ''}
                    </div>
                </div>
                <div class="pool-item-head">
                    <div>
                        <strong>${escapeHtml(pool.name)}</strong>
                    </div>
                    <div class="pool-balance-group">
                        <span class="pool-balance">${formatMoney(pool.availableBalance)}</span>
                        ${pool.totalWithdrawals > 0 || pool.startingBalance > 0 ? `<span class="pool-balance-sub">from ${formatMoney(pool.balance)} saved</span>` : ''}
                    </div>
                </div>
                <div class="pool-meta">
                    ${!isRollover ? `<span>${pool.linkedCategories.length} linked ${pool.linkedCategories.length === 1 ? 'category' : 'categories'}</span>` : ''}
                    ${pool.target ? `<span>${Math.min((pool.availableBalance / pool.target) * 100, 999).toFixed(0)}% of target</span>` : (!isRollover ? '<span>No target</span>' : '')}
                </div>
                ${targetMarkup}
                ${categoriesMarkup}
                ${historyMarkup}
                
                ${!isRollover && !pool.isClosed ? `
                <div class="pool-actions">
                    <button class="btn-pool-withdraw" data-id="${pool.id}" data-name="${escapeHtml(pool.name)}">
                        Withdraw
                    </button>
                    ${pool.withdrawals && pool.withdrawals.length > 0 ? `
                    <button class="btn-pool-history-toggle" data-id="${pool.id}">
                        History
                    </button>
                    ` : ''}
                </div>
                ` : !isRollover && pool.isClosed && pool.withdrawals && pool.withdrawals.length > 0 ? `
                <div class="pool-actions">
                    <button class="btn-pool-history-toggle" data-id="${pool.id}">
                        View History
                    </button>
                </div>
                ` : ''}
            </article>
        `;
    }

    function renderPools(pools: Pool[]) {
        currentPools = pools;
        const yearlyRolloverEl = document.getElementById('yearly-rollover');
        const poolsGrid = document.getElementById('savings-pools-grid');
        const rollover = pools.find((pool) => pool.type === 'rollover');
        const savingsPools = pools.filter((pool) => pool.type === 'savings');
        
        const addPoolCard = `
            <button class="pool-add-card" id="btn-add-pool" type="button">
                <span class="pool-add-mark">+</span>
                <span class="pool-add-copy">
                    <strong>New pool</strong>
                    <span>Create a custom savings pool</span>
                </span>
            </button>
        `;

        if (yearlyRolloverEl && rollover) {
            yearlyRolloverEl.textContent = formatMoney(rollover.balance);
        }

        if (!poolsGrid) return;

        if (savingsPools.length === 0) {
            poolsGrid.innerHTML = `
                <div class="pool-item empty-pool">
                    <strong>No savings pools yet</strong>
                    <span>Create a pool to group categories like travel, repairs, or annual bills.</span>
                </div>
                ${addPoolCard}
            `;
            attachPoolHandlers();
            return;
        }

        poolsGrid.innerHTML = `${savingsPools.map(renderPoolCard).join('')}${addPoolCard}`;
        attachPoolHandlers();
    }

    function attachPoolHandlers() {
        document.getElementById('btn-add-pool')?.addEventListener('click', () => {
            renderPoolCategoryOptions();
            openPoolModal();
        });

        document.getElementById('btn-edit-bank')?.addEventListener('click', async () => {
            const user = await API.getUser();
            openBankModal(user.bankBalance);
        });

        document.querySelectorAll('.btn-pool-edit').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = (e.currentTarget as HTMLElement).dataset.id!;
                const pool = currentPools.find(p => p.id === id);
                if (pool) {
                    renderPoolCategoryOptions(pool.linkedCategoryIds);
                    openPoolModal(pool);
                }
            });
        });

        document.querySelectorAll('.btn-pool-withdraw').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const b = e.currentTarget as HTMLElement;
                openWithdrawModal(b.dataset.id!, b.dataset.name!);
            });
        });

        document.querySelectorAll('.btn-pool-history-toggle').forEach(btn => {
            btn.addEventListener('click', (e) => {
                const id = (e.currentTarget as HTMLElement).dataset.id;
                const h = document.getElementById(`history-${id}`);
                if (h) h.style.display = h.style.display === 'none' ? 'block' : 'none';
            });
        });

        document.querySelectorAll('.btn-pool-status').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                const b = e.currentTarget as HTMLElement;
                const poolId = b.dataset.id!;
                const isClosed = b.dataset.closed === 'true';
                
                if (!isClosed) {
                    if (!confirm('Mark this pool as completed? This will hide withdrawal actions.')) return;
                }
                
                await API.togglePoolStatus(poolId, !isClosed);
                renderYearly();
            });
        });
    }

    function openBankModal(current: number) {
        const modal = document.getElementById('bank-modal');
        const input = document.getElementById('bank-amount') as HTMLInputElement;
        if (!modal || !input) return;
        input.value = current.toString();
        modal.style.display = 'flex';
    }

    function closeBankModal() {
        const modal = document.getElementById('bank-modal');
        if (modal) modal.style.display = 'none';
    }

    async function saveBankBalance() {
        const amount = Number((document.getElementById('bank-amount') as HTMLInputElement).value);
        if (isNaN(amount)) return;
        
        await API.updateUser({ bankBalance: amount });
        UI.showToast('Bank balance updated');
        closeBankModal();
        renderYearly();
    }

    function openWithdrawModal(id: string, name: string) {
        const modal = document.getElementById('withdraw-modal');
        const title = document.getElementById('withdraw-pool-name');
        const idInput = document.getElementById('withdraw-pool-id') as HTMLInputElement;
        if (!modal || !title || !idInput) return;
        
        title.textContent = name;
        idInput.value = id;
        modal.style.display = 'flex';
        
        UI.initDateInputBounds('withdraw-date');
    }

    function closeWithdrawModal() {
        const modal = document.getElementById('withdraw-modal');
        if (modal) modal.style.display = 'none';
        
        (document.getElementById('withdraw-amount') as HTMLInputElement).value = '';
        (document.getElementById('withdraw-desc') as HTMLInputElement).value = '';
    }

    async function submitWithdrawal() {
        const id = (document.getElementById('withdraw-pool-id') as HTMLInputElement).value;
        const amount = Number((document.getElementById('withdraw-amount') as HTMLInputElement).value);
        const description = (document.getElementById('withdraw-desc') as HTMLInputElement).value;
        const date = (document.getElementById('withdraw-date') as HTMLInputElement).value;

        if (!amount || amount <= 0) {
            UI.showToast('Enter a valid amount');
            return;
        }

        try {
            await API.withdrawFromPool({ poolId: id, amount, description, date });
            UI.showToast('Withdrawal recorded');
            closeWithdrawModal();
            renderYearly();
        } catch (e) {
            UI.showToast('Error recording withdrawal');
        }
    }

    function renderPoolCategoryOptions(selectedIds: string[] = []) {
        const picker = document.getElementById('pool-category-picker');
        if (!picker) return;

        picker.innerHTML = expenseCategories.map((category) => `
            <label class="pool-category-option">
                <input type="checkbox" value="${category.id}" ${selectedIds.includes(category.id) ? 'checked' : ''}>
                <span class="pool-category-copy">
                    <span class="pool-category-swatch" style="background: ${category.color}20; color: ${category.color}">
                        ${escapeHtml(category.emoji)}
                    </span>
                    <span>${escapeHtml(category.name)}</span>
                </span>
            </label>
        `).join('');
    }

    function resetPoolForm() {
        (document.getElementById('pool-id') as HTMLInputElement).value = '';
        (document.getElementById('pool-name') as HTMLInputElement).value = '';
        (document.getElementById('pool-starting-balance') as HTMLInputElement).value = '';
        (document.getElementById('pool-target') as HTMLInputElement).value = '';
        document.querySelectorAll<HTMLInputElement>('#pool-category-picker input[type="checkbox"]').forEach(c => c.checked = false);
        
        document.getElementById('pool-modal-title')!.textContent = 'Create Savings Pool';
        document.getElementById('btn-delete-pool')!.style.display = 'none';
        document.getElementById('btn-save-pool')!.textContent = 'Save Pool';
    }

    function openPoolModal(pool?: Pool) {
        const modal = document.getElementById('pool-modal');
        if (!modal) return;
        
        resetPoolForm();
        
        if (pool) {
            document.getElementById('pool-modal-title')!.textContent = 'Edit Savings Pool';
            (document.getElementById('pool-id') as HTMLInputElement).value = pool.id;
            (document.getElementById('pool-name') as HTMLInputElement).value = pool.name;
            (document.getElementById('pool-starting-balance') as HTMLInputElement).value = pool.startingBalance?.toString() || '';
            (document.getElementById('pool-target') as HTMLInputElement).value = pool.target?.toString() || '';
            document.getElementById('btn-delete-pool')!.style.display = 'block';
            document.getElementById('btn-save-pool')!.textContent = 'Update Pool';
            
            // Checks for checkboxes should be handled by renderPoolCategoryOptions call
        }
        
        modal.style.display = 'flex';
    }

    function closePoolModal() {
        const modal = document.getElementById('pool-modal');
        if (modal) modal.style.display = 'none';
    }

    async function savePool() {
        const poolId = (document.getElementById('pool-id') as HTMLInputElement).value;
        const nameInput = document.getElementById('pool-name') as HTMLInputElement;
        const startBalInput = document.getElementById('pool-starting-balance') as HTMLInputElement;
        const targetInput = document.getElementById('pool-target') as HTMLInputElement;
        const selectedCategories = Array.from(
            document.querySelectorAll<HTMLInputElement>('#pool-category-picker input[type="checkbox"]:checked')
        ).map((checkbox) => checkbox.value);

        const name = nameInput.value.trim();
        if (!name) {
            UI.showToast('Pool name is required');
            return;
        }

        if (selectedCategories.length === 0) {
            UI.showToast('Pick at least one expense category');
            return;
        }

        const startBal = Number(startBalInput.value || 0);
        const targetValue = targetInput.value.trim();
        const target = targetValue ? Number(targetValue) : null;

        try {
            if (poolId) {
                await API.updatePool({
                    poolId,
                    name,
                    startingBalance: startBal,
                    target,
                    linkedCategoryIds: selectedCategories
                });
                UI.showToast('Pool updated');
            } else {
                await API.addPool({
                    name,
                    startingBalance: startBal,
                    target,
                    linkedCategoryIds: selectedCategories
                });
                UI.showToast('Pool created');
            }
            closePoolModal();
            renderYearly();
        } catch (e) {
            UI.showToast('Error saving pool');
        }
    }

    async function deletePool() {
        const poolId = (document.getElementById('pool-id') as HTMLInputElement).value;
        if (!poolId || !confirm('Are you sure you want to delete this pool? This cannot be undone.')) return;
        
        try {
            await API.deletePool(poolId);
            UI.showToast('Pool deleted');
            closePoolModal();
            renderYearly();
        } catch (e) {
            UI.showToast('Error deleting pool');
        }
    }

    function initPoolModal() {
        document.getElementById('btn-cancel-pool')?.addEventListener('click', closePoolModal);
        document.getElementById('btn-save-pool')?.addEventListener('click', savePool);
        document.getElementById('btn-delete-pool')?.addEventListener('click', deletePool);

        document.getElementById('pool-modal')?.addEventListener('click', (event) => {
            if (event.target === event.currentTarget) closePoolModal();
        });

        // Withdraw modal listeners
        document.getElementById('btn-cancel-withdraw')?.addEventListener('click', closeWithdrawModal);
        document.getElementById('btn-confirm-withdraw')?.addEventListener('click', submitWithdrawal);

        // Bank modal listeners
        document.getElementById('btn-cancel-bank')?.addEventListener('click', closeBankModal);
        document.getElementById('btn-save-bank')?.addEventListener('click', saveBankBalance);
    }

    async function renderYearly() {
        const year = Store.getCurrentYear();
        
        // Use useData for snappy, cached data retrieval
        const [all, pools, user] = await Promise.all([
            useData(DataSpecs.AllRecords()),
            useData(DataSpecs.Pools(year)),
            useData(DataSpecs.User())
        ]);
        const yearlyGrid = document.getElementById('yearly-months-grid');
        const yearlyBankEl = document.getElementById('yearly-bank-balance');

        if (yearlyBankEl) {
            yearlyBankEl.textContent = formatMoney(user.bankBalance);
        }

        if (user.bankBalance === 0 && !sessionStorage.getItem('bank_prompted')) {
            openBankModal(0);
            sessionStorage.setItem('bank_prompted', 'true');
        }
        
        const monthsData = Array.from({length: 12}, (_, i) => ({
            index: i,
            name: new Date(year, i).toLocaleDateString('es-ES', { month: 'long' }),
            income: 0,
            expense: 0
        }));

        all.forEach(r => {
            const d = new Date(r.date);
            if (d.getFullYear() === year) {
                const m = d.getMonth();
                if (r.type === 'income') monthsData[m].income += r.amount;
                else monthsData[m].expense += r.amount;
            }
        });

        if (yearlyGrid) {
            yearlyGrid.innerHTML = monthsData.map(m => {
                const net = m.income - m.expense;
                const isFuture = m.index > new Date().getMonth() && year === new Date().getFullYear();
                
                return `
                    <div class="month-card ${isFuture ? 'future' : ''}">
                        <span class="m-name">${m.name}</span>
                        <div class="m-stats">
                            <div class="m-stat-row income">
                                <span class="m-stat-label">
                                    <span class="m-stat-icon">↑</span>
                                    <span>Income</span>
                                </span>
                                <span class="m-stat-value">${formatMoney(m.income)}</span>
                            </div>
                            <div class="m-stat-row expense">
                                <span class="m-stat-label">
                                    <span class="m-stat-icon">↓</span>
                                    <span>Expenses</span>
                                </span>
                                <span class="m-stat-value">${formatMoney(m.expense)}</span>
                            </div>
                        </div>
                        <div class="m-net" style="color: ${net >= 0 ? 'var(--accent)' : 'var(--danger)'}">
                            ${net >= 0 ? '+' : ''}€${net.toFixed(2)}
                        </div>
                    </div>
                `;
            }).join('');
        }

        renderPools(pools);
        
        // Sidebar total for current month specifically (using same logic as other pages)
        const currentMonthRecords = all.filter(r => {
            const date = new Date(r.date);
            return date.getMonth() === Store.getCurrentMonth();
        });
        Renderers.renderSidebarTotal(currentMonthRecords);
    }

    document.addEventListener('astro:page-load', async () => {
        UI.initSidebar();
        const hasUser = await API.requireUser();
        if (!hasUser) return;
        
        // Use useData for category list as well
        const categoryList = await useData(DataSpecs.CategoryList());
        expenseCategories = categoryList.filter((category) => category.type === 'expense');
        
        initPoolModal();
        UI.initMonthNavigation(renderYearly);
        UI.bindDataRefresh(renderYearly);
        renderYearly();
    });
</script>
