---
---
<section class="stats-row" id="stats-row" aria-label="Monthly Statistics">
    <div class="stat-card accent-card" id="card-total">
        <div class="s-label" id="label-total">Total Spent</div>
        <div class="s-value" id="stat-total">€0.00</div>
        <div class="s-sub">this month</div>
    </div>
    <div class="stat-card" id="card-remaining">
        <div class="s-label" id="label-remaining">Remaining Income</div>
        <div class="s-value" id="stat-remaining">€0.00</div>
        <div class="s-sub">monthly budget</div>
    </div>
    <div class="stat-card" id="card-avg">
        <div class="s-label">Avg / Day</div>
        <div class="s-value" id="stat-avg">€0</div>
        <div class="s-sub" id="stat-avg-sub">—</div>
    </div>
</section>
