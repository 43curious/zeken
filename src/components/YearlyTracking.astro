<div class="yearly-dashboard">
    <header class="yearly-header">
        <div class="summary-pool-grid">
            <div class="pool-card bank-account" id="card-bank-account">
                <span class="pool-label">Bank account</span>
                <span class="pool-amt" id="yearly-bank-balance">€0.00</span>
                <span class="pool-sub">Current available funds</span>
                <button class="btn-edit-balance" id="btn-edit-bank">Edit</button>
            </div>
            <div class="pool-card rollover" id="card-rollover">
                <span class="pool-label">Total Savings</span>
                <span class="pool-amt" id="yearly-rollover">€0.00</span>
                <span class="pool-sub">Cumulative net worth across time</span>
            </div>
        </div>
    </header>

    <section class="savings-pools">
        <div class="section-header">
            <h3>Money pools</h3>
        </div>
        <div class="pools-grid" id="savings-pools-grid">
            <!-- Pools will be rendered here -->
        </div>
    </section>

    <section class="yearly-grid-section">
        <h3>Monthly breakdown</h3>
        <div class="yearly-months-grid" id="yearly-months-grid">
            <!-- 12 month cards will be rendered here -->
        </div>
    </section>
</div>

<!-- Pool Modal (Creation & Edit) -->
<div id="pool-modal" class="modal" style="display: none;">
    <div class="modal-content pool-modal-content">
        <h3 id="pool-modal-title">Create Savings Pool</h3>
        <input type="hidden" id="pool-id">
        <div class="form-group">
            <label for="pool-name">Name</label>
            <input type="text" id="pool-name" placeholder="e.g. Phone savings">
        </div>
        <div class="form-group">
            <label for="pool-starting-balance">Money inside the pool already</label>
            <input type="number" id="pool-starting-balance" min="0" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
            <label for="pool-target">Target amount (optional)</label>
            <input type="number" id="pool-target" min="0" step="0.01" placeholder="e.g. 1200">
        </div>
        <div class="form-group">
            <label>Linked expense categories</label>
            <div class="pool-category-picker" id="pool-category-picker">
                <!-- Category options will be rendered here -->
            </div>
        </div>
        <div class="modal-actions">
            <button id="btn-delete-pool" class="btn-discard" style="margin-right: auto; background: #fee2e2; color: #dc2626; border-color: #fca5a5; display: none;">Delete Pool</button>
            <button id="btn-cancel-pool" class="btn-discard">Cancel</button>
            <button id="btn-save-pool" class="btn-confirm">Save Pool</button>
        </div>
    </div>
</div>

<div id="withdraw-modal" class="modal" style="display: none;">
    <div class="modal-content pool-modal-content">
        <h3 id="withdraw-title">Withdraw from Pool</h3>
        <p id="withdraw-pool-name" style="margin-top: -12px; margin-bottom: 24px; color: var(--muted); font-weight: 600;"></p>
        <input type="hidden" id="withdraw-pool-id">
        <div class="form-group">
            <label for="withdraw-amount">Amount</label>
            <input type="number" id="withdraw-amount" min="0.01" step="0.01" placeholder="0.00">
        </div>
        <div class="form-group">
            <label for="withdraw-desc">Description</label>
            <input type="text" id="withdraw-desc" placeholder="e.g. Bought the phone">
        </div>
        <div class="form-group">
            <label for="withdraw-date">Date</label>
            <input type="date" id="withdraw-date">
        </div>
        <div class="modal-actions">
            <button id="btn-cancel-withdraw" class="btn-discard">Cancel</button>
            <button id="btn-confirm-withdraw" class="btn-confirm">Confirm Withdrawal</button>
        </div>
    </div>
</div>

<div id="bank-modal" class="modal" style="display: none;">
    <div class="modal-content pool-modal-content">
        <h3>Bank account balance</h3>
        <p style="margin-top: -12px; margin-bottom: 24px; color: var(--muted); font-size: 14px;">
            Set your current bank account balance. This will be updated automatically as you record income and expenses.
        </p>
        <div class="form-group">
            <label for="bank-amount">Current Balance</label>
            <input type="number" id="bank-amount" step="0.01" placeholder="0.00">
        </div>
        <div class="modal-actions">
            <button id="btn-cancel-bank" class="btn-discard">Cancel</button>
            <button id="btn-save-bank" class="btn-confirm">Save Balance</button>
        </div>
    </div>
</div>

