---
const pathname = new URL(Astro.request.url).pathname;
const isActive = (path: string) => (pathname === path ? "active" : "");
const user = Astro.locals.user;
---

<aside class="sidebar" id="sidebar">
    <button
        class="sidebar-toggle"
        id="sidebar-toggle"
        title="Toggle Sidebar"
        aria-label="Toggle Sidebar"
    >
        <span></span>
        <span></span>
        <span></span>
    </button>
    <div class="logo">Zeken<span>smart budgeting</span></div>

    <div class="nav-section">Views</div>
    <a
        href="/dashboard"
        class={`nav-item ${isActive("/dashboard")}`}
        id="nav-dashboard"
        data-astro-prefetch
    >
        <span class="nav-icon">⌂</span>
        <span>Dashboard</span>
    </a>
    <a 
        href="/income" 
        class={`nav-item ${isActive("/income")}`} 
        id="nav-income"
        data-astro-prefetch
    >
        <span class="nav-icon">↗</span>
        <span>Income</span>
    </a>
    <a 
        href="/yearly" 
        class={`nav-item ${isActive("/yearly")}`} 
        id="nav-yearly"
        data-astro-prefetch
    >
        <span class="nav-icon">▥</span>
        <span>Yearly</span>
    </a>
    <a
        href="/all-expenses"
        class={`nav-item ${isActive("/all-expenses")}`}
        id="nav-all"
        data-astro-prefetch
    >
        <span class="nav-icon">☰</span>
        <span>Transactions</span>
    </a>
    <a
        href="/calendar"
        class={`nav-item ${isActive("/calendar")}`}
        id="nav-calendar"
        data-astro-prefetch
    >
        <span class="nav-icon">□</span>
        <span>Calendar</span>
    </a>
    <a
        href="/categories"
        class={`nav-item ${isActive("/categories")}`}
        id="nav-categories"
        data-astro-prefetch
    >
        <span class="nav-icon">◫</span>
        <span>Categories</span>
    </a>

    <div class="nav-section">System</div>
    <a
        href="/settings"
        class={`nav-item ${isActive("/settings") || isActive("/profile")}`}
        id="nav-settings"
        title="Settings"
        data-astro-prefetch
    >
        <span class="nav-icon">⚙</span>
        <span>Settings</span>
    </a>
    {
        user?.role === "admin" && (
            <a
                href="/admin"
                class={`nav-item ${isActive("/admin")}`}
                id="nav-admin"
                title="Admin"
                data-astro-prefetch
            >
                <span class="nav-icon">★</span>
                <span>Admin Console</span>
            </a>
        )
    }

    <div class="sidebar-total">
        <div class="label">This month</div>
        <div class="amount" id="sidebar-total">€0.00</div>
    </div>
</aside>

<script>
    import { prewarm, DataSpecs } from '../lib/app.data';
    import { Store } from '../lib/store';

    function initPrefetchHandlers() {
        const year = Store.getCurrentYear();
        const month = Store.getCurrentMonth();

        // Dashboard prewarm
        document.getElementById('nav-dashboard')?.addEventListener('mouseenter', () => {
            prewarm(DataSpecs.MonthlyRecords(year, month));
            prewarm(DataSpecs.Pools(year));
        });

        // Yearly prewarm
        document.getElementById('nav-yearly')?.addEventListener('mouseenter', () => {
            prewarm(DataSpecs.AllRecords());
            prewarm(DataSpecs.Pools(year));
        });

        // Transactions prewarm
        document.getElementById('nav-all')?.addEventListener('mouseenter', () => {
            prewarm(DataSpecs.AllRecords());
        });

        // Categories prewarm
        document.getElementById('nav-categories')?.addEventListener('mouseenter', () => {
            prewarm(DataSpecs.Categories());
        });

        // Settings/User prewarm
        document.getElementById('nav-settings')?.addEventListener('mouseenter', () => {
            prewarm(DataSpecs.User());
        });
    }

    document.addEventListener('astro:page-load', initPrefetchHandlers);
</script>
